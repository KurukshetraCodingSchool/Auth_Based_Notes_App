<%- include('partials/header') %>
<link rel="stylesheet" href="/stylesheets/profile.css">
<%- include('partials/flash') %>
<%- include('partials/nav') %>

<div class="container">
    <h2>Welcome <%= User.username %> 👋👋 </h2> <br>
<h3>This Is Your Dashboard</h3>
<a href="/addnote">➕ Add Note</a>
<hr>

<% notes.forEach(note=>{ %>
<div class="note-card">
    <h3><%= note.title %></h3>
    <p><%= note.content %></p>
    <div class="edit">
    <h4><a href="/edit/<%= note._id %> ">edit</a></h4>
    <a href="/delete/<%= note._id %> ">Delete</a>
    </div>
</div>
<% }) %>
</div>
 
<%- include('partials/footer')%>